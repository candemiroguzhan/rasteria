<Window x:Class="Rasteria.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Rasteria.UI.Controls"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Rasteria"
        Height="860"
        Width="1380"
        MinHeight="700"
        MinWidth="1080"
        Icon="images/rasteria_icon.png"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource Brush.AppBackground}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="58"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Grid Background="{StaticResource Brush.AppBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="58" />
            <RowDefinition Height="*" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource Brush.Panel}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,0,1">
            <DockPanel Margin="14,0">
                <DockPanel DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Margin="0,0,18,0">
                    <Border Width="34"
                            Height="34"
                            Margin="0,0,10,0"
                            ClipToBounds="True">
                        <Image Source="./images/rasteria_icon.png"
                               Width="34"
                               Height="34"
                               Stretch= "None" />
                    </Border>
                    <StackPanel>
                        <TextBlock Text="Rasteria"
                                   FontSize="18"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Lightweight Raster Viewer"
                                   FontSize="11"
                                   Foreground="{StaticResource Brush.Muted}" />
                    </StackPanel>
                </DockPanel>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource ToolbarButton}"
                            Command="{Binding ToggleLayerPanelCommand}"
                            Content="{Binding LayerManagerToggleText}"
                            ToolTip="{Binding LayerManagerToggleText}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}"
                            Command="{Binding ToggleMetadataPanelCommand}"
                            Content="{Binding MetadataToggleText}"
                            ToolTip="{Binding MetadataToggleText}"
                            Margin="8,0,0,0"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    </Button>
                    <Border Width="1"
                            Height="28"
                            Background="{StaticResource Brush.Border}"
                            Margin="10,0,6,0" />
                    <Button Style="{StaticResource WindowCaptionButton}"
                            Click="MinimizeButton_Click"
                            ToolTip="Minimize"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <iconPacks:PackIconMaterial Kind="WindowMinimize" Width="12" Height="12" />
                    </Button>
                    <Button Style="{StaticResource WindowCaptionButton}"
                            Click="MaximizeRestoreButton_Click"
                            ToolTip="Maximize"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <iconPacks:PackIconMaterial x:Name="MaximizeRestoreIcon" Kind="WindowMaximize" Width="12" Height="12" />
                    </Button>
                    <Button Style="{StaticResource WindowCaptionButton}"
                            Click="CloseButton_Click"
                            ToolTip="Close"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <iconPacks:PackIconMaterial Kind="WindowClose" Width="12" Height="12" />
                    </Button>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource ToolbarButton}"
                            Command="{Binding OpenRasterCommand}"
                            ToolTip="Open raster">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="FolderOpen" Width="14" Height="14" />
                            <TextBlock Text="Open Raster" Margin="7,0,0,0" />
                        </StackPanel>
                    </Button>
                    <Border Width="1"
                            Height="26"
                            Background="{StaticResource Brush.Border}"
                            Margin="8,0" />
                    <Button Style="{StaticResource ToolbarButton}"
                            Command="{Binding ZoomInCommand}"
                            ToolTip="Zoom in">
                        <iconPacks:PackIconMaterial Kind="MagnifyPlusOutline" Width="14" Height="14" />
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}"
                            Command="{Binding ZoomOutCommand}"
                            ToolTip="Zoom out">
                        <iconPacks:PackIconMaterial Kind="MagnifyMinusOutline" Width="14" Height="14" />
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}"
                            Command="{Binding FitRasterCommand}"
                            ToolTip="Fit raster">
                        <iconPacks:PackIconMaterial Kind="FitToPageOutline" Width="14" Height="14" />
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1"
              Margin="10"
              ClipToBounds="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding LayerPanelWidth}" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="{Binding MetadataPanelWidth}" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource Brush.Panel}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="8"
                    ClipToBounds="True"
                    Margin="0,0,10,0">
                <DockPanel>
                    <Grid Margin="14">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLayerPanelOpen}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top"
                                       Style="{StaticResource PanelTitle}"
                                       Text="LAYER MANAGER" />
                            <ListBox ItemsSource="{Binding Layers}"
                                     SelectedItem="{Binding SelectedLayer}"
                                     HorizontalContentAlignment="Stretch">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource Brush.PanelAlt}"
                                                BorderBrush="{StaticResource Brush.Border}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="10"
                                                Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <CheckBox IsChecked="{Binding IsVisible, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          Grid.Column="0"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,10,0" />
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding Kind}"
                                                               Foreground="{StaticResource Brush.Muted}"
                                                               FontSize="11"
                                                               Margin="0,2,0,0" />
                                                    <Grid Margin="0,10,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   Text="Opacity"
                                                                   Foreground="{StaticResource Brush.Muted}"
                                                                   FontSize="11"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,10,0" />
                                                        <Slider Grid.Column="1"
                                                                Minimum="0"
                                                                Maximum="1"
                                                                Value="{Binding Opacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                VerticalAlignment="Center" />
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding Opacity, StringFormat={}{0:P0}}"
                                                                   Foreground="{StaticResource Brush.Muted}"
                                                                   FontSize="11"
                                                                   VerticalAlignment="Center"
                                                                   Margin="10,0,0,0" />
                                                    </Grid>
                                                    <Button Content="Remove Raster"
                                                            Command="{Binding DataContext.RemoveLayerCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource ToolbarButton}"
                                                            HorizontalAlignment="Left"
                                                            Margin="0,10,0,0"
                                                            ToolTip="Remove selected raster" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Grid>
                </DockPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="{StaticResource Brush.Viewport}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="8"
                    ClipToBounds="True">
                <controls:MapViewer x:Name="RasterMap"
                                    RasterLayers="{Binding Layers}"
                                    SelectedRasterMetadata="{Binding ActiveRasterMetadata}"
                                    ZoomLevel="{Binding ZoomLevel, Mode=TwoWay}"
                                    MouseImagePosition="{Binding MouseImagePosition, Mode=TwoWay}"
                                    ClipToBounds="True"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch" />
            </Border>

            <Border Grid.Column="2"
                    Background="{StaticResource Brush.Panel}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="8"
                    ClipToBounds="True"
                    Margin="10,0,0,0">
                <DockPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Margin="14">
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMetadataPanelOpen}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <TextBlock Style="{StaticResource PanelTitle}"
                                       Text="METADATA" />

                            <Border Style="{StaticResource MetadataCard}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource PropertyLabel}" Text="File name" />
                                    <TextBlock Text="{Binding FileName}" TextWrapping="Wrap" />
                                    <TextBlock Style="{StaticResource PropertyLabel}" Text="Type" />
                                    <TextBlock Text="{Binding MetadataTypeText}" />
                                    <TextBlock Style="{StaticResource PropertyLabel}" Text="Format" />
                                    <TextBlock Text="{Binding FormatText}" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource MetadataCard}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource PropertyLabel}" Text="Raster size" />
                                    <TextBlock Text="{Binding RasterSizeText}" />
                                    <TextBlock Style="{StaticResource PropertyLabel}" Text="Band count" />
                                    <TextBlock Text="{Binding BandCountText}" />
                                    <TextBlock Style="{StaticResource PropertyLabel}" Text="Resolution" />
                                    <TextBlock Text="{Binding ResolutionText}" />
                                    <TextBlock Style="{StaticResource PropertyLabel}" Text="No-data value" />
                                    <TextBlock Text="{Binding NoDataText}" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource MetadataCard}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource PropertyLabel}" Text="CRS" />
                                    <TextBlock Text="{Binding CrsText}" TextWrapping="Wrap" />
                                    <TextBlock Style="{StaticResource PropertyLabel}" Text="Bounds" />
                                    <TextBlock Text="{Binding BoundsText}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource Brush.Panel}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,1,0,0">
            <DockPanel Margin="12,0">
                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding CrsStatusText}"
                           VerticalAlignment="Center"
                           Margin="0,0,24,0"
                           Foreground="{StaticResource Brush.Muted}" />
                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding CoordinateText}"
                           VerticalAlignment="Center"
                           Margin="0,0,24,0"
                           Foreground="{StaticResource Brush.Muted}" />
                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding ZoomText}"
                           VerticalAlignment="Center"
                           Margin="0,0,24,0"
                           Foreground="{StaticResource Brush.Muted}" />
                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding ActiveLayerText, StringFormat=Raster: {0}}"
                           VerticalAlignment="Center"
                           Margin="0,0,24,0"
                           Foreground="{StaticResource Brush.Muted}" />
                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding LoadingStateText}"
                           VerticalAlignment="Center"
                           Margin="0,0,24,0"
                           Foreground="{StaticResource Brush.Muted}" />
                <TextBlock Text="{Binding Status}"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
